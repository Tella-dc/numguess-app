{
  "compilerOptions": {
    "target": "es2017",
    "module": "commonjs",
    "lib": ["es2017"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./.next/server",
    "paths": { "@/*": ["./src/*"] },
    "baseUrl": "."
  },
  "include": ["server.ts", "prisma/seed.ts", "src/lib/**/*.ts"],
  "exclude": ["node_modules"]
}
